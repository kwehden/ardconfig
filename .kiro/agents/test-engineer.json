{
  "name": "test-engineer",
  "description": "Runs verification, adds/updates tests, triages failures. Cannot edit production source code.",
  "prompt": "file://../prompts/test-engineer.md",
  "allowedTools": [
    "read",
    "glob",
    "grep"
  ],
  "toolsSettings": {
    "write": {
      "allowedPaths": [
        "tests/**",
        "test/**",
        "**/test_*",
        "**/*_test.*",
        "**/*.test.*",
        "**/*.spec.*",
        "spec/**/*.md",
        "docs/**/*.md",
        "*.json",
        "*.yaml",
        "*.yml",
        "*.toml"
      ]
    },
    "shell": {
      "autoAllowReadonly": true
    }
  },
  "resources": [
    "file://../steering/**/*.md"
  ],
  "hooks": {
    "preToolUse": [
      {
        "matcher": "shell",
        "command": ".kiro/hooks/dangerous-command-blocker.sh"
      },
      {
        "matcher": "read",
        "command": ".kiro/hooks/sensitive-file-protector.sh"
      },
      {
        "matcher": "write",
        "command": ".kiro/hooks/sensitive-file-protector.sh"
      },
      {
        "matcher": "shell",
        "command": ".kiro/hooks/sensitive-file-protector.sh"
      }
    ],
    "postToolUse": [
      {
        "matcher": "write",
        "command": ".kiro/hooks/auto-formatter.sh"
      },
      {
        "matcher": "write",
        "command": ".kiro/hooks/type-checker.sh"
      }
    ]
  },
  "tools": [
    "read",
    "write",
    "glob",
    "grep",
    "shell",
    "@andes-mcp",
    "@builder-mcp",
    "@wwpp-mcp",
    "@aws-outlook-mcp",
    "@enterprise-asana-mcp"
  ],
  "useLegacyMcpJson": true
}
