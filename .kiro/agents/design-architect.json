{
  "name": "design-architect",
  "description": "Produces spec/design.md with architecture, interfaces, failure modes, and rollout plan.",
  "prompt": "file://../prompts/design-architect.md",
  "allowedTools": [
    "read",
    "glob",
    "grep",
    "thinking"
  ],
  "toolsSettings": {
    "write": {
      "allowedPaths": [
        "spec/design.md"
      ]
    }
  },
  "resources": [
    "file://../steering/**/*.md"
  ],
  "hooks": {
    "preToolUse": [
      {
        "matcher": "read",
        "command": ".kiro/hooks/sensitive-file-protector.sh"
      },
      {
        "matcher": "write",
        "command": ".kiro/hooks/sensitive-file-protector.sh"
      }
    ]
  },
  "tools": [
    "read",
    "write",
    "glob",
    "grep",
    "thinking",
    "@andes-mcp",
    "@builder-mcp",
    "@wwpp-mcp",
    "@aws-outlook-mcp",
    "@enterprise-asana-mcp"
  ],
  "useLegacyMcpJson": true
}
