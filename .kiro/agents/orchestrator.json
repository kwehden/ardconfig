{
  "name": "orchestrator",
  "description": "Spec-driven coordinator that delegates to specialist agents, enforces quality gates, and chains post-execution verification.",
  "prompt": "file://../prompts/orchestrator.md",
  "toolsSettings": {
    "write": {
      "allowedPaths": [
        "spec/post-execution-log.md"
      ]
    },
    "subagent": {
      "availableAgents": [
        "repo-governor",
        "spec-coordinator",
        "requirements-engineer",
        "design-architect",
        "task-planner",
        "executor",
        "test-engineer",
        "security-sentinel",
        "eval-engineer",
        "docs-release",
        "code-reviewer",
        "postmortem-scribe",
        "mcp-toolsmith"
      ],
      "trustedAgents": [
        "repo-governor",
        "spec-coordinator",
        "requirements-engineer",
        "design-architect",
        "task-planner",
        "docs-release",
        "code-reviewer",
        "postmortem-scribe"
      ]
    }
  },
  "resources": [
    "file://../steering/**/*.md"
  ],
  "hooks": {
    "preToolUse": [
      {
        "matcher": "read",
        "command": ".kiro/hooks/sensitive-file-protector.sh"
      },
      {
        "matcher": "write",
        "command": ".kiro/hooks/sensitive-file-protector.sh"
      }
    ]
  },
  "welcomeMessage": "System2 orchestrator ready. Checking spec state...",
  "tools": [
    "read",
    "write",
    "glob",
    "grep",
    "shell",
    "code",
    "thinking",
    "subagent",
    "web_search",
    "web_fetch",
    "use_aws",
    "knowledge",
    "introspect",
    "todo_list",
    "@andes-mcp",
    "@builder-mcp",
    "@wwpp-mcp",
    "@aws-outlook-mcp",
    "@enterprise-asana-mcp"
  ],
  "useLegacyMcpJson": true
}
