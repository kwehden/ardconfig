{
  "name": "requirements-engineer",
  "description": "Translates spec/context.md into EARS requirements with validation and traceability.",
  "prompt": "file://../prompts/requirements-engineer.md",
  "allowedTools": [
    "read",
    "glob",
    "grep",
    "thinking"
  ],
  "toolsSettings": {
    "write": {
      "allowedPaths": [
        "spec/requirements.md"
      ]
    }
  },
  "resources": [
    "file://../steering/**/*.md"
  ],
  "hooks": {
    "preToolUse": [
      {
        "matcher": "read",
        "command": ".kiro/hooks/sensitive-file-protector.sh"
      },
      {
        "matcher": "write",
        "command": ".kiro/hooks/sensitive-file-protector.sh"
      }
    ]
  },
  "tools": [
    "read",
    "write",
    "glob",
    "grep",
    "thinking",
    "@andes-mcp",
    "@builder-mcp",
    "@wwpp-mcp",
    "@aws-outlook-mcp",
    "@enterprise-asana-mcp"
  ],
  "useLegacyMcpJson": true
}
