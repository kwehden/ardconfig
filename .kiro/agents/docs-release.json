{
  "name": "docs-release",
  "description": "Updates documentation, changelog, and release notes with user-facing impact focus.",
  "prompt": "file://../prompts/docs-release.md",
  "allowedTools": [
    "read",
    "glob",
    "grep"
  ],
  "toolsSettings": {
    "write": {
      "allowedPaths": [
        "README.md",
        "CHANGELOG.md",
        "MIGRATIONS.md",
        "docs/**/*.md",
        "spec/**/*.md"
      ]
    }
  },
  "resources": [
    "file://../steering/**/*.md"
  ],
  "hooks": {
    "preToolUse": [
      {
        "matcher": "read",
        "command": ".kiro/hooks/sensitive-file-protector.sh"
      },
      {
        "matcher": "write",
        "command": ".kiro/hooks/sensitive-file-protector.sh"
      }
    ]
  },
  "tools": [
    "read",
    "write",
    "glob",
    "grep",
    "@andes-mcp",
    "@builder-mcp",
    "@wwpp-mcp",
    "@aws-outlook-mcp",
    "@enterprise-asana-mcp"
  ],
  "useLegacyMcpJson": true
}
