{
  "name": "eval-engineer",
  "description": "Creates regression evals for agentic or LLM features with goldens and metrics.",
  "prompt": "file://../prompts/eval-engineer.md",
  "allowedTools": [
    "read",
    "glob",
    "grep"
  ],
  "toolsSettings": {
    "write": {
      "allowedPaths": [
        "spec/evals.md",
        "evals/**"
      ]
    },
    "shell": {
      "autoAllowReadonly": true
    }
  },
  "resources": [
    "file://../steering/**/*.md"
  ],
  "hooks": {
    "preToolUse": [
      {
        "matcher": "shell",
        "command": ".kiro/hooks/dangerous-command-blocker.sh"
      },
      {
        "matcher": "read",
        "command": ".kiro/hooks/sensitive-file-protector.sh"
      },
      {
        "matcher": "write",
        "command": ".kiro/hooks/sensitive-file-protector.sh"
      },
      {
        "matcher": "shell",
        "command": ".kiro/hooks/sensitive-file-protector.sh"
      }
    ],
    "postToolUse": [
      {
        "matcher": "write",
        "command": ".kiro/hooks/auto-formatter.sh"
      },
      {
        "matcher": "write",
        "command": ".kiro/hooks/type-checker.sh"
      }
    ]
  },
  "tools": [
    "read",
    "write",
    "glob",
    "grep",
    "shell",
    "@andes-mcp",
    "@builder-mcp",
    "@wwpp-mcp",
    "@aws-outlook-mcp",
    "@enterprise-asana-mcp"
  ],
  "useLegacyMcpJson": true
}
